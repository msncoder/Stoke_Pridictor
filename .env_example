# SMAP-FYP Backend Configuration (Example)
# Duplicate this file as '.env' and fill in your actual credentials.

# --- Neon PostgreSQL (Required) ---
# Connection string format: postgres://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgres://user:password@hostname.neon.tech/neondb?sslmode=require

# --- API Settings ---
PORT=8000
LOG_LEVEL=INFO

# --- External Services (Optional) ---
# Memcached Configuration
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# Spark & Hadoop Configuration
SPARK_HOME=C:\spark
PYSPARK_PYTHON=python
# HDFS Support (pydoop required)
HDFS_ENABLED=false
